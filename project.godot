; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Dino TCG"
run/main_scene="uid://ny6i18slc4m1"
config/features=PackedStringArray("4.4", "Forward Plus")

[autoload]

GameState="*res://Scripts/Core/GameState.gd"
TurnManager="*res://Scripts/Core/TurnManager.gd"
CardDatabase="*res://Scripts/Data/CardDatabase.gd"
SetupManager="*res://Scripts/Core/SetupManager.gd"
BattleManager="*res://Scripts/Core/BattleManager.gd"
DeckManager="*res://Scripts/Data/DeckManager.gd"
MatchData="*res://Scripts/Data/MatchData.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_card_layout/plugin.cfg")

[importer_defaults]

csv_translation={
&"compress": false
}
